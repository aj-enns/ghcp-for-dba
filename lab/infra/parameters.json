{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "eastus"
    },
    "aadAdminLogin": {
      "value": "<user-principal-name>"
    },
    "aadAdminObjectId": {
      "value": "<azure-ad-object-id>"
    },
